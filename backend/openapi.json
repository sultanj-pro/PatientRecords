    "description": "Minimal API spec for development — includes auth and patient endpoints."
  },
  "servers": [
    { "url": "http://localhost:5001", "description": "Local dev" }
  ],
  "tags": [
    { "name": "System", "description": "System health and status endpoints" },
    { "name": "Authentication", "description": "User authentication and token management" },
    { "name": "Patient Demographics", "description": "Patient demographics and general information" },
    { "name": "Vitals", "description": "Patient vital signs management" },
    { "name": "Labs", "description": "Patient laboratory results management" },
    { "name": "Medications", "description": "Patient medication records management" },
    { "name": "Physician Visits", "description": "Patient physician visit records" },
