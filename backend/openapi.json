    },
    "/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Login (returns JWT)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "username": { "type": "string" } },
                "required": ["username"]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful" },
          "400": { "description": "Bad request" }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["Authentication"],
        "summary": "Refresh token",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "token": { "type": "string" } } } } }
        },
        "responses": { "200": { "description": "Token refreshed" }, "400": { "description": "Bad request" } }
      }
    },
