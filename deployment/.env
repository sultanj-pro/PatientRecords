# PatientRecords Environment Configuration
# Copy this file to .env and customize for your environment
# SECURITY: Never commit the .env file to git (add to .gitignore)
# SECURITY: Keep credentials secure and rotate regularly

# ==========================================
# Environment Selection
# ==========================================
# Options: development, staging, production
NODE_ENV=development

# ==========================================
# Backend API Configuration
# ==========================================
# Port for backend API server
PORT=5001

# JWT Configuration
# SECURITY: Must be at least 32 characters, random alphanumeric
# Generate with: openssl rand -base64 32
# NEVER use the default 'dev-secret' in any real environment
JWT_SECRET=your-very-secret-jwt-key-must-be-32-chars-minimum-change-this

# JWT expiration time in seconds (default: 3600 = 1 hour)
JWT_EXPIRATION=3600

# JWT refresh token expiration in seconds (default: 604800 = 7 days)
JWT_REFRESH_EXPIRATION=604800

# ==========================================
# MongoDB Configuration
# ==========================================
# SECURITY: Use strong passwords, different for each environment
# Format: mongodb://username:password@host:port/database?authSource=authDB

# MongoDB connection URI
# Local development example:
# MONGODB_URI=mongodb://admin:admin@localhost:27017/patientrecords?authSource=admin
# Docker development example:
# MONGODB_URI=mongodb://admin:admin@patientrecord-mongodb:27017/patientrecords?authSource=admin
# Atlas cloud example:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/patientrecords?retryWrites=true&w=majority
MONGODB_URI=mongodb://admin:admin@patientrecord-mongodb:27017/patientrecords?authSource=admin

# MongoDB root admin credentials (for docker-compose initialization only)
# Only used when starting MongoDB container
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin

# MongoDB database name
MONGODB_DATABASE=patientrecords

# ==========================================
# Frontend Service URLs
# ==========================================
# In production, backend should be behind a reverse proxy
# BACKEND_URL should be your domain/API endpoint, not localhost

# Backend API URL (as accessed from frontend)
# Development: http://localhost:5001
# Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:5001
REACT_APP_API_URL=http://localhost:5001

# ==========================================
# Service Ports (for local development)
# ==========================================
# DO NOT change these unless you know what you're doing
# These match docker-compose.yml port mappings

SHELL_APP_PORT=4200
DEMOGRAPHICS_PORT=4201
VITALS_PORT=4202
LABS_PORT=4203
MEDICATIONS_PORT=4204
VISITS_PORT=4205
BACKEND_PORT=5001
MONGODB_PORT=27017

# ==========================================
# HTTPS/TLS Configuration (Production Only)
# ==========================================
# SSL certificate paths (absolute paths or relative to docker-compose)
# For production, use a reverse proxy (nginx/traefik) for HTTPS termination

# Path to SSL certificate file
SSL_CERT_PATH=/etc/ssl/certs/your-cert.pem

# Path to SSL private key file
SSL_KEY_PATH=/etc/ssl/private/your-key.pem

# Enable HTTPS enforcement
ENABLE_HTTPS=false

# ==========================================
# CORS Configuration
# ==========================================
# Comma-separated list of allowed origins
# Development: http://localhost:4200,http://localhost:4201,http://localhost:4202,http://localhost:4203,http://localhost:4204,http://localhost:4205
# Production: https://yourdomain.com,https://api.yourdomain.com

CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:4201,http://localhost:4202,http://localhost:4203,http://localhost:4204,http://localhost:4205

# ==========================================
# Logging Configuration
# ==========================================
# Log level: error, warn, info, debug, trace
LOG_LEVEL=info

# Enable file logging (in addition to console)
LOG_TO_FILE=false

# Log directory (if file logging enabled)
LOG_FILE_PATH=/var/log/patientrecords

# ==========================================
# Session/Security Configuration
# ==========================================
# Session timeout in milliseconds (30 minutes)
SESSION_TIMEOUT=1800000

# Enable debug mode (disable in production)
DEBUG_MODE=true

# Token refresh buffer (refresh token if expiring within this many seconds)
TOKEN_REFRESH_BUFFER=300

# ==========================================
# Security Headers
# ==========================================
# Content Security Policy enforcement
CSP_ENABLED=false

# HSTS (HTTP Strict Transport Security) max age in seconds (1 year = 31536000)
HSTS_MAX_AGE=31536000

# ==========================================
# Backup & Persistence Configuration
# ==========================================
# Directory for MongoDB backups (host path for docker volumes)
BACKUP_DIR=/backups/mongodb

# Backup retention period in days
BACKUP_RETENTION_DAYS=30

# Enable automatic backups
ENABLE_AUTO_BACKUP=false

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * * # 2 AM daily

# ==========================================
# Data Configuration
# ==========================================
# Enable sample data seeding on startup
SEED_SAMPLE_DATA=true

# Number of sample patients to create (development only)
SAMPLE_PATIENT_COUNT=5

# ==========================================
# Feature Flags
# ==========================================
# Enable allergies feature
FEATURE_ALLERGIES=true

# Enable audit logging
FEATURE_AUDIT_LOGGING=false

# Enable role-based access control
FEATURE_RBAC=false

# ==========================================
# Integration Endpoints (Optional)
# ==========================================
# Third-party service integrations

# Email service for notifications
EMAIL_SERVICE_URL=

# SMS service for alerts
SMS_SERVICE_URL=

# External lab system integration
LAB_SYSTEM_URL=

# Pharmacy system integration
PHARMACY_SYSTEM_URL=

# ==========================================
# Performance Tuning
# ==========================================
# Connection pool size for MongoDB
MONGODB_POOL_SIZE=10

# Query timeout in milliseconds
QUERY_TIMEOUT=30000

# Cache TTL in seconds (0 = disabled)
CACHE_TTL=300

# ==========================================
# Monitoring & Observability
# ==========================================
# Prometheus metrics endpoint
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# OpenTelemetry/APM endpoint
APM_ENABLED=false
APM_ENDPOINT=

# Health check endpoint path
HEALTH_CHECK_PATH=/health

# ==========================================
# Development Tools (Development Only)
# ==========================================
# Enable API request logging
API_REQUEST_LOG=true

# Enable performance profiling
PROFILING_ENABLED=false

# Enable CORS in dev mode
CORS_DEBUG=true

# ==========================================
# Notes
# ==========================================
# 1. Keep production credentials in a secure secrets manager
#    (AWS Secrets Manager, Azure Key Vault, HashiCorp Vault, etc.)
#
# 2. Rotate credentials regularly (minimum quarterly for production)
#
# 3. Use environment-specific .env files:
#    - .env.development (local development)
#    - .env.staging (staging environment)
#    - Don't commit .env files with real credentials
#
# 4. In CI/CD, pull secrets from secure storage, not files
#
# 5. Audit all environment variable changes
#
# 6. Document all custom environment variables added by your team
#
# 7. For production deployments without .env files:
#    Export environment variables in your deployment script:
#    export MONGODB_URI="mongodb://..."
#    export JWT_SECRET="..."
#    docker-compose up -d
