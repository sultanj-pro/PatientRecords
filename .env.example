# Storage provider selection for development
STORAGE_PROVIDER=delta-minio

# MinIO dev settings (do NOT commit real secrets)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_CONSOLE_ENDPOINT=http://minio:9001

# JDBC example (Postgres) - only used when STORAGE_PROVIDER is set to a jdbc provider
# Example: JDBC_URL=postgres://user:password@db:5432/patientdb
JDBC_URL=
JDBC_USER=
JDBC_PASSWORD=
JDBC_DRIVER=org.postgresql.Driver
JDBC_SSL=false

# CI / GitHub Actions
# The integration workflow writes a .env from repository secrets before running
# Docker Compose. Create these repository secrets in your GitHub repo settings:
# - PR_DB_HOST    (for example: clonet-postgresql)
# - PR_DB_NAME    (for example: patientrecords)
# - PR_DB_USER    (for example: pr_user)
# - PR_DB_PASSWORD (example: pr_pass)
#
# The workflow will synthesize the following variables into `.env`:
# - JDBC_URL (postgres://${PR_DB_USER}:${PR_DB_PASSWORD}@${PR_DB_HOST}:5432/${PR_DB_NAME})
# - JDBC_USER
# - JDBC_PASSWORD
#
# For local testing, copy this file to `.env` and fill the JDBC_* values, then:
#
#   docker compose -f docker-compose.yml -f docker-compose.override.postgres.yml up -d --build
#
