{
  "name": "patient-records-frontend",
  "version": "0.1.0",
  "description": "PatientRecords Micro-Frontend Application",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "npm run start:shell",
    "start:shell": "cd shell-app && npm start",
    "start:modules": "npm run start:demographics & npm run start:vitals & npm run start:labs & npm run start:medications & npm run start:visits",
    "start:all": "npm run start:shell & npm run start:modules",
    "start:demographics": "cd modules/demographics && npm start",
    "start:vitals": "cd modules/vitals && npm start",
    "start:labs": "cd modules/labs && npm start",
    "start:medications": "cd modules/medications && npm start",
    "start:visits": "cd modules/visits && npm start",
    "build": "npm run build:shared && npm run build:modules && npm run build:shell",
    "build:shell": "cd shell-app && npm run build",
    "build:modules": "npm run build:demographics && npm run build:vitals && npm run build:labs && npm run build:medications && npm run build:visits",
    "build:demographics": "cd modules/demographics && npm run build",
    "build:vitals": "cd modules/vitals && npm run build",
    "build:labs": "cd modules/labs && npm run build",
    "build:medications": "cd modules/medications && npm run build",
    "build:visits": "cd modules/visits && npm run build",
    "build:shared": "cd shared && npm run build",
    "test": "npm run test:shell && npm run test:modules && npm run test:shared",
    "test:shell": "cd shell-app && npm test",
    "test:shared": "cd shared && npm test",
    "test:modules": "npm run test:demographics && npm run test:vitals && npm run test:labs && npm run test:medications && npm run test:visits",
    "test:demographics": "cd modules/demographics && npm test",
    "test:vitals": "cd modules/vitals && npm test",
    "test:labs": "cd modules/labs && npm test",
    "test:medications": "cd modules/medications && npm test",
    "test:visits": "cd modules/visits && npm test",
    "lint": "npm run lint:shell && npm run lint:modules && npm run lint:shared",
    "lint:shell": "cd shell-app && npm run lint",
    "lint:shared": "cd shared && npm run lint",
    "lint:modules": "npm run lint:demographics && npm run lint:vitals && npm run lint:labs && npm run lint:medications && npm run lint:visits",
    "lint:demographics": "cd modules/demographics && npm run lint",
    "lint:vitals": "cd modules/vitals && npm run lint",
    "lint:labs": "cd modules/labs && npm run lint",
    "lint:medications": "cd modules/medications && npm run lint",
    "lint:visits": "cd modules/visits && npm run lint"
  },
  "workspaces": [
    "shell-app",
    "modules/demographics",
    "modules/vitals",
    "modules/labs",
    "modules/medications",
    "modules/visits",
    "shared"
  ],
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.0.0",
    "@angular/cli": "^17.0.0",
    "@angular/compiler-cli": "^17.0.0",
    "@types/jasmine": "^5.0.0",
    "jasmine-core": "^5.0.0",
    "karma": "^6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.0",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "typescript": "^5.2.0"
  }
}
